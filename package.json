{
  "name": "nextjs-fullstack-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=20",
    "bun": ">=1.3"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "validate:agents-md": "bun run scripts/validate-agents-md.ts",
    "knip": "knip",
    "jscpd": "jscpd --config .jscpd.json",
    "depcruise": "dependency-cruiser src/",
    "check:todos": "bun run scripts/check-todos.mjs",
    "check:todos:strict": "bun run scripts/check-todos.mjs --require-ticket",
    "docs:generate": "bun run scripts/generate-docs.mjs",
    "docs:check": "bun run scripts/generate-docs.mjs --check",
    "analyze:bundle": "ANALYZE=true bun run build",
    "prepare": "husky",
    "postinstall": "node scripts/patch-eslint-plugin-react.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@better-auth/drizzle-adapter": "1.6.23",
    "@hugeicons/core-free-icons": "4.2.2",
    "@hugeicons/react": "1.1.9",
    "@neondatabase/serverless": "1.1.0",
    "@react-pdf/renderer": "4.5.1",
    "@t3-oss/env-nextjs": "0.13.11",
    "@tanstack/react-table": "8.21.3",
    "@types/papaparse": "5.5.2",
    "better-auth": "1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "4.4.4",
    "dexie-react-hooks": "4.4.0",
    "drizzle-orm": "0.45.2",
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "papaparse": "5.5.4",
    "pino": "10.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.13.0",
    "sonner": "2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "3.6.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@next/bundle-analyzer": "16.2.10",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "3.6.4",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "babel-plugin-react-compiler": "1.0.0",
    "dependency-cruiser": "18.1.0",
    "drizzle-kit": "0.31.10",
    "eslint": "^10",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jscpd": "5.0.12",
    "jsdom": "29.1.1",
    "knip": "6.26.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
