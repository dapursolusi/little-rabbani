# =============================================================================
# Environment Variables -- Little Rabbani
# =============================================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
#
# WARNING: Never commit `.env`, `.env.local`, `.env.development`, or
# `.env.production` to version control. They contain secrets.
# =============================================================================

# -- Database ------------------------------------------------------------------
# Neon PostgreSQL connection string (or any Postgres URL).
DATABASE_URL=

# -- Authentication (Better Auth) ----------------------------------------------
# Generate a random secret with:  openssl rand -hex 32
BETTER_AUTH_SECRET=

# Google OAuth credentials (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -- App URL -------------------------------------------------------------------
# Public-facing URL of the application.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth URL (typically same as APP_URL for local dev).
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# -- AI / OpenRouter -----------------------------------------------------------
# API key for OpenRouter (https://openrouter.ai/keys).
OPENROUTER_API_KEY=

# OpenRouter model identifier (optional, defaults to deepseek-v4-flash).
OPENROUTER_MODEL=deepseek-v4-flash

# -- Feature Flags --------------------------------------------------------------
# Set to "1" or "true" to enable a feature flag. Omit or set to "0"/"false" to disable.
FF_NEW_DASHBOARD=
FF_NEW_AUTH_FLOW=
FF_NEW_ONBOARDING=
FF_EXPERIMENTAL_SEARCH=

# -- shadcn UI Blocks -----------------------------------------------------------
# API key for shadcn UI blocks registry (optional, only needed for block development).
SHADCN_UI_BLOCKS_API_KEY=
