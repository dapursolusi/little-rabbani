# =============================================================================
# Environment Variables -- Little Rabbani
# =============================================================================
# Copy this file to .env.local (or .env.development/.env.production) and fill
# in the values.
#   cp .env.example .env.local
# =============================================================================

# -- Database ------------------------------------------------------------------
# Neon PostgreSQL connection string (or any Postgres URL).
DATABASE_URL=

# -- Authentication (Better Auth) ----------------------------------------------
# Generate a random secret with:  openssl rand -hex 32
BETTER_AUTH_SECRET=

# Google OAuth credentials (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -- App URL -------------------------------------------------------------------
# Public-facing URL of the application.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth URL (typically same as APP_URL for local dev).
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# -- AI / OpenRouter -----------------------------------------------------------
# API key for OpenRouter (https://openrouter.ai/keys).
OPENROUTER_API_KEY=
