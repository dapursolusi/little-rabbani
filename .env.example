# =============================================================================
# Environment Variables -- Little Rabbani
# =============================================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
#
# WARNING: Never commit `.env`, `.env.local`, or any other `.env.*` file
# to version control. They contain secrets.
#
# Production secrets go in the deploy provider dashboard (Vercel, etc.),
# never in a file.
# =============================================================================

# -- Database ------------------------------------------------------------------
# Neon PostgreSQL connection string (or any Postgres URL).
DATABASE_URL=

# -- Authentication (Better Auth) ----------------------------------------------
# Generate a random secret with:  openssl rand -hex 32
BETTER_AUTH_SECRET=

# Better Auth URL (typically same as APP_URL for local dev).
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth credentials (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dev auth bypass — set to "1" only in development; never in production.
DEV_AUTH_BYPASS=0

# -- App URL -------------------------------------------------------------------
# Public-facing URL of the application (required for sitemap, OG metadata, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth client URL (typically same as NEXT_PUBLIC_APP_URL).
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# -- AI / OpenRouter -----------------------------------------------------------
# API key for OpenRouter (https://openrouter.ai/keys).
OPENROUTER_API_KEY=

# OpenRouter model identifier (optional, defaults to deepseek/deepseek-v4-flash).
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# -- Push Notifications (VAPID) ------------------------------------------------
# VAPID keys for web push notifications.
# Generate with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# -- Feature Flags (optional, omit = disabled) ---------------------------------
# Set to "1" to enable a feature flag. Omit or set to "0" to disable.
# FF_NEW_DASHBOARD=1
# FF_NEW_AUTH_FLOW=1
# FF_NEW_ONBOARDING=1
# FF_EXPERIMENTAL_SEARCH=1

# -- Logging -------------------------------------------------------------------
# Log level: debug, info, warn, error (default: info in prod, debug in dev).
# LOG_LEVEL=debug

# -- shadcn UI Blocks (optional, only needed for block development) ------------
# SHADCN_UI_BLOCKS_API_KEY=
