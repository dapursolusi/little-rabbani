{
  "mcpServers": {
    "magicuidesign-mcp": {
      "type": "stdio",
      "command": "bunx",
      "args": ["--bun", "-y", "@magicuidesign/mcp@latest"]
    },
    "playwright": {
      "type": "stdio",
      "command": "bunx",
      "args": ["--bun", "-y", "@playwright/mcp@latest"],
      "disabled": false
    },
    "shadcn": {
      "type": "stdio",
      "command": "bunx",
      "args": ["--bun", "-y", "shadcn@latest", "mcp"],
      "disabled": false
    },
    "neon": {
      "url": "https://mcp.neon.tech/mcp",
      "disabled": false,
      "type": "http"
    }
  }
}
